# NovelForge Core 配置文件示例
# 复制此文件为 .env 并填入您的配置

# ============ AI 服务配置 ============
# 方式1: 直接使用 OpenAI 兼容 API (推荐)

# API Key (必填)
OPENAI_API_KEY=your-api-key-here

# API Base URL (可选，默认为 OpenAI 官方)
# 示例:
# - SiliconFlow: https://api.siliconflow.cn/v1
# - DeepSeek: https://api.deepseek.com/v1
# - 本地 Ollama: http://localhost:11434/v1
OPENAI_BASE_URL=https://api.siliconflow.cn/v1

# 模型名称 (可选，默认为 gpt-4o-mini)
# 示例:
# - SiliconFlow DeepSeek: Pro/deepseek-ai/DeepSeek-V3.2
# - DeepSeek: deepseek-chat
# - 本地 Ollama: llama3
OPENAI_MODEL=Pro/deepseek-ai/DeepSeek-V3.2

# ============ SillyTavern 配置 ============
# 方式2: 使用 SillyTavern 后端 (可选)
# SILLYTAVERN_URL=http://localhost:8000

# ============ 提取配置 ============
# 单次分析最大文本长度
MAX_TEXT_LENGTH=5000

# 最大提取角色数
MAX_CHARACTERS=20

# 重试次数
RETRY_COUNT=3

# 重试延迟(秒)
RETRY_DELAY=1.0
