# NovelForge Core 配置文件示例
# 复制此文件为 .env 并填入您的配置

# ============ AI 服务配置 ============
# 方式1: 直接使用 OpenAI 兼容 API (推荐)

# API Key (必填)
OPENAI_API_KEY=your-api-key-here

# API Base URL (可选，默认为 OpenAI 官方)
# 示例:
# - SiliconFlow: https://api.siliconflow.cn/v1
# - DeepSeek: https://api.deepseek.com/v1
# - 本地 Ollama: http://localhost:11434/v1
OPENAI_BASE_URL=https://api.siliconflow.cn/v1

# 模型名称 (可选，默认为 gpt-4o-mini)
# 示例:
# - SiliconFlow DeepSeek: Pro/deepseek-ai/DeepSeek-V3.2
# - DeepSeek: deepseek-chat
# - 本地 Ollama: llama3
OPENAI_MODEL=Pro/deepseek-ai/DeepSeek-V3.2
# 是否强制只使用当前模型（true 时不自动回退其它模型）
OPENAI_STRICT_MODEL=false
# Optional comma-separated fallback models, useful for self-hosted gateways.
# Example: gemini-2.5-flash,gpt-4o-mini
OPENAI_FALLBACK_MODELS=

# ============ SillyTavern 配置 ============
# 方式2: 使用 SillyTavern 后端 (可选)
# SILLYTAVERN_URL=http://localhost:8000

# ============ 提取配置 ============
# 单次分析最大文本长度
MAX_TEXT_LENGTH=5000

# 最大提取角色数
MAX_CHARACTERS=20

# 提取温度（控制AI提取的确定性，值越低越确定）
EXTRACTION_TEMPERATURE=0.3

# 创作温度（控制AI创作的创造性，值越高越有创意）
CREATIVE_TEMPERATURE=0.8

# ============ 并发与性能配置 ============
# 最小并发数
MIN_CONCURRENCY=2

# 最大并发数
MAX_CONCURRENCY=10

# 目标成功率（用于动态调整并发）
TARGET_SUCCESS_RATE=0.95

# 目标响应时间（秒）
TARGET_RESPONSE_TIME=5.0

# ============ 限流配置 ============
# 每分钟请求数限制 (RPM)
RPM_LIMIT=500

# 每分钟令牌数限制 (TPM)
TPM_LIMIT=2000000

# ============ 重试配置 ============
# 最大重试次数
MAX_RETRIES=5

# 重试基础延迟（秒）
RETRY_BASE_DELAY=2.0

# 重试最大延迟（秒）
RETRY_MAX_DELAY=120.0

# ============ 存储配置 ============
# 存储类型 (file, database, content_db)
STORAGE_TYPE=file
# 是否将内容资产写入 SQLite 内容库
USE_CONTENT_DATABASE=false
# 可选：统一数据根目录（留空时默认为 novelforge-core/data）
NOVELFORGE_DATA_DIR=
# 可选：文件存储目录（会保存会话、任务等 JSON）
FILE_STORAGE_DIR=

# 通用键值数据库路径（用于 STORAGE_TYPE=database）
DATABASE_PATH=
# 内容资产数据库路径（用于内容资产永久化）
CONTENT_DATABASE_PATH=

# ============ 日志配置 ============
# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 结构化日志输出
STRUCTURED_LOGGING=true
