# ===========================================================
# NovelForge 根目录 .gitignore
# 
# 仓库只追踪：
#   - novelforge-core/   (核心项目)
#   - docs/              (项目文档)
#   - README.md          (项目说明)
#   - START_GUIDE.md     (启动指南)
# ===========================================================

# -----------------------------------------------------------
# 开源子项目（不属于本仓库，各自有独立仓库）
# -----------------------------------------------------------
SillyTavern/

# -----------------------------------------------------------
# 运行时数据目录（不提交本地数据）
# -----------------------------------------------------------
data/
archives/
workspace/

# -----------------------------------------------------------
# 运行日志和测试报告
# -----------------------------------------------------------
*.log
backend_test_report_*.json
backend.log

# -----------------------------------------------------------
# Python 编译缓存 & 虚拟环境
# -----------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/
.coverage
htmlcov/

# -----------------------------------------------------------
# Python 构建产物
# -----------------------------------------------------------
build/
dist/
*.egg-info/
*.egg
wheels/
develop-eggs/
eggs/
.eggs/

# -----------------------------------------------------------
# 环境变量（含 API 密钥，绝不提交）
# -----------------------------------------------------------
.env
.env.local
.env.*.local

# -----------------------------------------------------------
# IDE / 编辑器
# -----------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------
# 操作系统产物
# -----------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------
# 工具内部目录
# -----------------------------------------------------------
.sisyphus/

# -----------------------------------------------------------
# Node.js（前端 node_modules 由 novelforge-core/.gitignore 处理，
# 但以防万一在根级也声明）
# -----------------------------------------------------------
node_modules/
.next/
.nuxt/
.cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
